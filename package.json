{
  "name": "Tetromino",
  "version": "1.0.0",
  "description": "One-way import from Are.na channels into your Obsidian vault.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production && node scripts/package.mjs",
    "package": "node scripts/package.mjs",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "validate": "npm run lint && npm test && npm run build",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "release": "bash scripts/release.sh"
  },
  "keywords": [
    "obsidian",
    "arena",
    "are.na",
    "import",
    "plugin"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "builtin-modules": "^5.2.0",
    "esbuild": "^0.28.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "jsdom": "^29.1.1",
    "obsidian": "1.13.1",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "js-yaml": "^4.1.2"
  }
}
